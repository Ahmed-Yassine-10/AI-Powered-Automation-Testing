# Copiez ce fichier en `.env` puis renseignez votre clé.
# `.env` est ignoré par Git — ne mettez JAMAIS de vraie clé dans .env.example.

OPENROUTER_API_KEY=sk-or-v1-VOTRE_CLE_ICI
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Durée max d'exécution d'un test (en secondes)
RUN_TIMEOUT=120

# Jeton facultatif protégeant l'endpoint CI /api/projects/:id/ci-run.
# Laissez vide pour désactiver la protection (usage local).
WEBHOOK_TOKEN=

FLASK_DEBUG=true
FLASK_PORT=5000
